# 1. Sử dụng Python bản nhẹ
FROM python:3.11-slim

# 2. Đặt thư mục làm việc
WORKDIR /app

# 3. Cài đặt các thư viện hệ thống cần thiết (nếu có)
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential && \
    rm -rf /var/lib/apt/lists/*

# 4. Copy và cài đặt thư viện Python
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# 5. Copy toàn bộ code vào
COPY . .

# 6. Tạo thư mục uploads nếu chưa có
RUN mkdir -p uploads

# 7. Chạy server uvicorn
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]